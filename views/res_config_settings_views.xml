<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_website_sale_marketplace_journal" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.website.sale.marketplace.journal</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='invoicing_settings']" position="inside">
                <setting
                    id="marketplace_sale_journal_setting"
                    string="Marketplace Sale Journal"
                    company_dependent="1"
                    help="Default journal used when invoicing website/e-commerce orders."
                >
                    <field
                        name="marketplace_sale_journal_id"
                        options="{'no_create': True, 'no_open': False}"
                    />
                    <div class="text-muted">
                        Must be a sales journal from the selected company.
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
