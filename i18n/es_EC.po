#. module: website_sale_marketplace_journal
#: model_terms:ir.ui.view,arch_db:website_sale_marketplace_journal.res_config_settings_view_form_website_sale_marketplace_journal
msgid "Must be a sales journal from the selected company."
msgstr "Debe ser un diario de ventas de la compania seleccionada."
